# Force LF line endings for all text files; matches Prettier's default endOfLine=lf.
* text=auto eol=lf

# Binary files — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
